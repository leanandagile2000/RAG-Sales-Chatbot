        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const content = $input.item.json.content;\nconst metadata = $input.item.json.metadata;\nconst fileName = $input.item.json.fileName;\n\nlet cleanedContent;\n\nif (metadata.doc_type === 'qbr_summary') {\n  // Keep QBR content as-is\n  cleanedContent = content.trim();\n} else {\n  // Strip everything before the first blank line\n  const parts = content.split('\\n\\n');\n  cleanedContent = parts.slice(1).join('\\n\\n').trim();\n}\n\n// Normalize whitespace\ncleanedContent = cleanedContent.replace(/\\n{3,}/g, '\\n\\n');\n\nreturn {\n  json: {\n    content: cleanedContent,\n    metadata: metadata,\n    fileName: fileName\n  }\n};"
      },
